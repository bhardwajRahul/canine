<%
  color_styles = {
    'green' => { bg: 'rgba(22, 163, 74, 0.1)', text: '#4ade80', border: 'rgba(22, 163, 74, 0.3)' },
    'yellow' => { bg: 'rgba(202, 138, 4, 0.1)', text: '#facc15', border: 'rgba(202, 138, 4, 0.3)' },
    'red' => { bg: 'rgba(220, 38, 38, 0.1)', text: '#f87171', border: 'rgba(220, 38, 38, 0.3)' }
  }
  colors = color_styles[color] || color_styles['green']
%>
<div style="background-color: <%= colors[:bg] %>; border: 1px solid <%= colors[:border] %>; border-radius: 0.5rem; padding: 1.25rem;">
  <p style="font-size: 0.875rem; font-weight: 500; color: #8a909a; margin: 0 0 0.25rem 0;"><%= title %></p>
  <p style="font-size: 1.875rem; font-weight: 700; color: <%= colors[:text] %>; margin: 0;"><%= value %></p>
  <p style="font-size: 0.75rem; color: #787f8a; margin: 0.25rem 0 0 0;"><%= detail %></p>
</div>
