<div class="flex items-center gap-3">
  <div class="text-2xl">
    <%= cluster_icon(item) %>
  </div>
  <div class="flex-1 min-w-0">
    <div class="font-semibold"><%= item.name %></div>
    <div class="text-sm text-base-content/60">
      <%= item.cluster_type.upcase %> · <%= pluralize(item.projects.size, "project") %> · <span class="text-success"><%= item.status.capitalize %></span>
    </div>
  </div>
</div>
