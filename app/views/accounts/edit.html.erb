<%= settings_layout do %>
  <div class="space-y-16">
    <div>
      <h2 class="text-2xl font-bold">Account</h2>
      <p class="text-xs text-gray-500 mt-1">ID: <%= current_account.id %></p>
      <hr class="mt-3 mb-4 border-t border-base-300" />

      <%= form_for(current_account, url: account_path(current_account), html: { method: :patch }) do |f| %>
        <div class="mb-3">
          <%= f.text_field :name, class: 'input input-bordered w-full focus:outline-offset-0', placeholder: "Account name" %>
        </div>

        <div class="form-control rounded-lg bg-base-200 p-2 px-4 max-w-sm mb-3">
          <label class="label mt-1">
            <span class="label-text cursor-pointer">Allow MCP access</span>
            <%= f.check_box :allow_mcp, class: "checkbox" %>
          </label>
        </div>

        <% mcp_modal_id = "mcp_setup_#{SecureRandom.hex(8)}" %>
        <a class="text-sm text-gray-500 hover:text-gray-300 cursor-pointer block mb-4"
           onclick="<%= mcp_modal_id %>.showModal()">
          How do I add this as an MCP server?
        </a>
        <dialog id="<%= mcp_modal_id %>" class="modal">
          <div class="modal-box w-11/12 max-w-2xl bg-base-300">
            <form method="dialog">
              <button aria-label="Close modal" class="btn btn-circle btn-ghost btn-sm absolute right-2 top-2">
                <iconify-icon icon="lucide:x" height="16"></iconify-icon>
              </button>
            </form>
            <h3 class="mb-6 text-xl font-bold">Adding Canine as an MCP server</h3>
            <p class="mb-4 text-sm text-base-content/70">Add the following to your MCP client configuration (e.g. Claude Desktop, Cursor):</p>
            <div class="mockup-code before:content-none mb-4">
              <pre><code>{
  "mcpServers": {
    "canine": {
      "url": "<%= request.base_url %>/mcp"
    }
  }
}</code></pre>
            </div>
            <p class="text-sm text-base-content/70">
              Your MCP server URL is: <span class="font-mono font-bold"><%= request.base_url %>/mcp</span>
            </p>
          </div>
          <form method="dialog" class="modal-backdrop">
            <button>close</button>
          </form>
        </dialog>

        <div class="mb-3">
          <%= f.submit "Save Account", class: 'btn btn-primary' %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
