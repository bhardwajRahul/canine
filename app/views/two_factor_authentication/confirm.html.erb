<%= settings_layout do %>
  <div class="max-w-lg">
    <h2 class="text-2xl font-bold">Save Your Recovery Codes</h2>
    <hr class="mt-3 mb-4 border-t border-base-300" />

    <div class="alert alert-warning mb-6">
      <iconify-icon icon="lucide:alert-triangle" class="text-lg"></iconify-icon>
      <span class="text-sm">Save these codes in a safe place. Each code can only be used once. You won't be able to see them again.</span>
    </div>

    <pre class="bg-base-200 rounded-lg p-4 mb-6 font-mono text-sm select-all whitespace-pre-wrap break-all"><%= @recovery_codes.join("\n") %></pre>

    <div class="flex gap-3">
      <button class="btn btn-outline btn-sm"
              data-controller="clipboard"
              data-clipboard-text="<%= @recovery_codes.join("\n") %>">
        <iconify-icon icon="lucide:copy" class="mr-1"></iconify-icon>
        Copy codes
      </button>
      <%= link_to "Done", edit_user_registration_path, class: "btn btn-primary btn-sm" %>
    </div>
  </div>
<% end %>
