<div class="w-full">
  <div class="grid gap-4" style="grid-template-columns: repeat(<%= stages.size %>, minmax(0, 1fr));">
    <% stages.each_with_index do |_step, i| %>
      <progress
        <% if current_stage == i %>
          data-controller="progress-progressing"
        <% end %>
        class="progress progress-primary w-full"
        <% if current_stage > i %>
          value="100"
        <% else %>
          value="0"
        <% end %>
        max="100">
      </progress>
    <% end %>
  </div>
  <div class="grid gap-4" style="grid-template-columns: repeat(<%= stages.size %>, minmax(0, 1fr));">
    <% stages.each_with_index do |step, i| %>
      <div class="flex items-center gap-1 text-sm <%= current_stage >= i ? "text-gray-300" : "text-gray-500" %>">
        <%= step %>
        <% if current_stage > i %>
          <iconify-icon class="text-success" icon="lucide:check"></iconify-icon>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
