<div class="flex justify-center items-center min-h-screen bg-base-200">
  <div class="card w-96 bg-base-100 shadow-xl">
    <div class="card-body">
      <h1 class="text-2xl font-bold text-center">Two-Factor Verification</h1>
      <p class="text-center text-sm text-gray-500 mt-1">Enter the code from your authenticator app or a recovery code</p>

      <%= form_with url: two_factor_verification_path, method: :post, html: { class: "space-y-4" }, data: { turbo: false } do |f| %>
        <% if flash[:alert] %>
          <div class="alert alert-error mb-4">
            <iconify-icon icon="lucide:alert-triangle" class="mr-2 text-white"></iconify-icon>
            <span><%= flash[:alert] %></span>
          </div>
        <% end %>

        <div class="form-control">
          <%= f.text_field :otp_attempt, placeholder: "6-digit code or recovery code", class: "input input-bordered w-full text-center text-lg tracking-widest", autocomplete: "one-time-code", required: true, autofocus: true %>
        </div>

        <div class="form-control mt-6">
          <%= f.submit "Verify", class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
