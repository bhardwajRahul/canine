<% content_for :meta_description, "Canine is an open source PaaS for Kubernetes. Deploy apps to your own cluster with the simplicity of Heroku and the power of Kubernetes." %>
<% content_for :og_description, "Canine is an open source PaaS for Kubernetes. Deploy apps to your own cluster with the simplicity of Heroku and the power of Kubernetes." %>
<% content_for :schema_json do %>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://canine.sh/#website",
      "name": "Canine",
      "url": "https://canine.sh",
      "publisher": {
        "@id": "https://canine.sh/#organization"
      }
    },
    {
      "@type": "Organization",
      "@id": "https://canine.sh/#organization",
      "name": "Canine",
      "url": "https://canine.sh",
      "logo": "https://canine.sh/icon.svg",
      "sameAs": [
        "https://github.com/CanineHQ/canine"
      ]
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://canine.sh/#software",
      "name": "Canine",
      "description": "A Developer-friendly PaaS for Kubernetes. Deploy applications to your own cluster with the simplicity of Heroku.",
      "url": "https://canine.sh",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
  ]
}
<% end %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" />
<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
<script>document.addEventListener("DOMContentLoaded", function() { AOS.init({ once: true, duration: 300, offset: 80, easing: "ease-out-cubic" }); });</script>

<div class="" style="">
  <%= render "static/landing_page/navbar" %>

  <div class="bg-gray-900">
    <main>
      <!-- Hero section -->
      <%= render "static/landing_page/hero" %>

      <!-- Open Source section -->
      <%= render "static/landing_page/open_source" %>

      <!-- Deploy section -->
      <%= render "static/landing_page/deploy" %>

      <!-- CLI Demo section -->
      <%= render "static/landing_page/cli_demo" %>

      <!-- Pricing section -->
      <%= render "static/landing_page/pricing" %>

      <!-- Feature section -->
      <%= render "static/landing_page/features_1" %>

      <!-- Feature section -->
      <%= render "static/landing_page/features_2" %>

      <!-- Funny -->
      <%= render "static/landing_page/why_not" %>

      <!-- CTA section -->
      <%= render "static/landing_page/cta" %>
    </main>

    <!-- Footer -->
    <%= render "static/landing_page/footer" %>
