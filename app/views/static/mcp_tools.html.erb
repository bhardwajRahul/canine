<% content_for :title, "MCP Server — Deploy and Debug from Claude Code, Cursor & more | Canine" %>
<% content_for :meta_description, "Canine's built-in MCP server lets you deploy, debug, and scale your Kubernetes apps directly from Claude Code, Cursor, or any MCP-compatible AI client. No dashboard required." %>
<% content_for :og_title, "Canine MCP Server — Control your infrastructure from your AI editor" %>
<% content_for :og_description, "Canine's built-in MCP server lets you deploy, debug, and scale your Kubernetes apps directly from Claude Code, Cursor, or any MCP-compatible AI client. No dashboard required." %>
<% content_for :og_image, "https://canine.sh/images/mcp-og-1200x630.webp" %>
<% content_for :schema_json do %>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://canine.sh/model-context-protocol#webpage",
      "url": "https://canine.sh/model-context-protocol",
      "name": "Canine MCP Server",
      "description": "Deploy, debug, and scale Kubernetes apps from Claude Code, Cursor, or any MCP-compatible AI client.",
      "isPartOf": { "@id": "https://canine.sh/#website" }
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://canine.sh/model-context-protocol#software",
      "name": "Canine MCP Server",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "description": "A Model Context Protocol server that lets AI clients deploy, debug, and manage Kubernetes applications.",
      "url": "https://canine.sh/model-context-protocol",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    }
  ]
}
<% end %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" />
<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
<script>
  ["DOMContentLoaded"].forEach(function(e) {
    document.addEventListener(e, function() { AOS.init({ once: true, duration: 300, offset: 80, easing: "ease-out-cubic" }); });
  });
</script>

<div class="bg-gray-900 min-h-screen">
  <%= render "static/landing_page/navbar" %>

  <main>
    <!-- Hero -->
    <div class="relative isolate">
      <div class="absolute inset-x-0 top-10 -z-10 flex transform-gpu justify-center overflow-hidden blur-3xl" aria-hidden="true">
        <div class="aspect-[1108/632] w-[69.25rem] flex-none bg-gradient-to-r from-[#10b981] to-[#6366f1] opacity-20" style="clip-path: polygon(73.6% 51.7%, 91.7% 11.8%, 100% 46.4%, 97.4% 82.2%, 92.5% 84.9%, 75.7% 64%, 55.3% 47.5%, 46.5% 49.4%, 45% 62.9%, 50.3% 87.2%, 21.3% 64.1%, 0.1% 100%, 5.4% 51.1%, 21.4% 63.9%, 58.9% 0.2%, 73.6% 51.7%)"></div>
      </div>

      <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-3xl text-center" data-aos="fade-up">
          <div class="inline-flex items-center gap-2 rounded-full bg-emerald-500/10 px-4 py-1.5 text-sm font-medium text-emerald-400 ring-1 ring-emerald-500/20 mb-8">
            <iconify-icon icon="lucide:cpu" class="text-base"></iconify-icon>
            Model Context Protocol
          </div>
          <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
            Your AI DevOps copilot
          </h1>
          <p class="mt-6 text-lg leading-8 text-gray-300 max-w-2xl mx-auto">
            Connect Claude Code or Cursor to your infrastructure and ship, debug, and scale without breaking your flow.
          </p>
          <div class="mt-10 flex items-center justify-center gap-x-6">
            <a href="<%= new_user_registration_path %>" class="rounded-md bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-emerald-400 transition">
              Get Started
            </a>
            <a href="https://docs.canine.sh" class="text-sm font-semibold text-white hover:text-emerald-400 transition">
              Read the docs <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Built-in MCP server -->
    <%= render "static/landing_page/mcp_preview" %>

    <!-- How it works -->
    <div id="how-it-works" class="mt-16 sm:mt-24 mx-auto max-w-7xl px-6 lg:px-8 pb-24">
      <div class="mx-auto max-w-4xl text-center mb-16" data-aos="fade-up">
        <h2 class="text-base font-semibold leading-7 text-emerald-400"><a href="#how-it-works" class="hover:underline underline-offset-4">How it works</a></h2>
        <p class="mt-2 text-2xl font-bold tracking-tight text-white sm:text-4xl"
           data-controller="typing"
           data-typing-words='["Claude Code","Cursor","Antigravity","Codex"]'
           data-typing-colors='["#D97757","#6B7EFF","#17BEBB","#10A37F"]'>
          Control your infrastructure from <span data-typing-target="typing"></span>
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
        <div class="relative rounded-2xl bg-gray-800/50 ring-1 ring-white/10 p-8" data-aos="fade-up" data-aos-delay="0">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400 text-xl font-bold mb-6">1</div>
          <h3 class="text-lg font-semibold text-white mb-2">Connect your AI client</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Point Claude Code, Cursor, or any MCP-compatible client at your Canine instance. OAuth handles the rest.</p>
        </div>
        <div class="relative rounded-2xl bg-gray-800/50 ring-1 ring-white/10 p-8" data-aos="fade-up" data-aos-delay="100">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400 text-xl font-bold mb-6">2</div>
          <h3 class="text-lg font-semibold text-white mb-2">Ask in natural language</h3>
          <p class="text-gray-400 text-sm leading-relaxed">"Show me the logs for my API service" or "Deploy the latest commit to staging." Just ask — Canine handles the rest.</p>
        </div>
        <div class="relative rounded-2xl bg-gray-800/50 ring-1 ring-white/10 p-8" data-aos="fade-up" data-aos-delay="200">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400 text-xl font-bold mb-6">3</div>
          <h3 class="text-lg font-semibold text-white mb-2">Infrastructure responds</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Canine executes the action on your cluster and returns structured results. Full audit trail, same permissions as the UI.</p>
        </div>
      </div>
    </div>

    <!-- All Tools -->
    <div id="what-you-can-do" class="mx-auto max-w-7xl px-6 py-24 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16" data-aos="fade-up">
        <h2 class="text-base font-semibold leading-7 text-emerald-400"><a href="#what-you-can-do" class="hover:underline underline-offset-4">What you can do</a></h2>
        <p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">Everything you need to operate</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-6 items-start" data-aos="fade-up">
        <!-- Tab list -->
        <div class="flex flex-col gap-2" id="terminal-tabs">
          <button onclick="switchTerminal('launch')" id="terminal-tab-launch"
            class="terminal-tab active flex items-center gap-3 w-full rounded-xl px-5 py-4 text-left transition-all bg-gray-800 ring-1 ring-emerald-500/50 text-white">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-emerald-500/10">
              <iconify-icon icon="lucide:rocket" class="text-emerald-400"></iconify-icon>
            </div>
            <div>
              <p class="text-sm font-semibold">Launching a project</p>
              <p class="text-xs text-gray-400 mt-0.5 hidden lg:block">From repo to running app</p>
            </div>
          </button>
          <button onclick="switchTerminal('debug')" id="terminal-tab-debug"
            class="terminal-tab flex items-center gap-3 w-full rounded-xl px-5 py-4 text-left transition-all bg-gray-800/50 ring-1 ring-white/10 text-gray-400 hover:text-white hover:bg-gray-800">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-amber-500/10">
              <iconify-icon icon="lucide:bug" class="text-amber-400"></iconify-icon>
            </div>
            <div>
              <p class="text-sm font-semibold">Debugging production</p>
              <p class="text-xs text-gray-400 mt-0.5 hidden lg:block">Find and fix issues fast</p>
            </div>
          </button>
          <button onclick="switchTerminal('ship')" id="terminal-tab-ship"
            class="terminal-tab flex items-center gap-3 w-full rounded-xl px-5 py-4 text-left transition-all bg-gray-800/50 ring-1 ring-white/10 text-gray-400 hover:text-white hover:bg-gray-800">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-violet-500/10">
              <iconify-icon icon="lucide:layers" class="text-violet-400"></iconify-icon>
            </div>
            <div>
              <p class="text-sm font-semibold">Shipping and managing</p>
              <p class="text-xs text-gray-400 mt-0.5 hidden lg:block">Deploy, scale, roll back</p>
            </div>
          </button>
        </div>

        <!-- Terminal panels -->
        <div>
          <!-- Launch -->
          <div id="terminal-panel-launch" class="rounded-xl overflow-hidden ring-1 ring-white/10 shadow-2xl">
            <div class="flex items-center gap-2 px-4 py-3 bg-gray-900 border-b border-white/10">
              <span class="w-3 h-3 rounded-full bg-red-500"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
              <span class="w-3 h-3 rounded-full bg-green-500"></span>
              <span class="ml-4 text-xs text-gray-500 font-mono">claude — claude-code</span>
              <span class="ml-auto text-xs text-emerald-500 font-mono flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
                canine MCP connected
              </span>
            </div>
            <div data-controller="terminal-animate"
                 data-terminal-animate-loop-value="true"
                 data-terminal-animate-lines-value='[
                   {"text":"On it. Creating the project, then I\u0027ll set the env var and spin up the database.","color":"#34d399"},
                   {"text":"→ create_project(name: \"api-service\", repo: \"my-org/api-service\", ...)","color":"#6b7280"},
                   {"text":"✓ Project created. First build queued.","color":"#34d399"},
                   {"text":"→ update_environment_variable(key: \"NODE_ENV\", value: \"production\", ...)","color":"#6b7280"},
                   {"text":"✓ Variable saved.","color":"#34d399"},
                   {"text":"→ create_add_on(name: \"api-service-db\", chart: \"bitnami/postgresql\", ...)","color":"#6b7280"},
                   {"text":"✓ Postgres installing. DATABASE_URL added to your environment.","color":"#34d399"},
                   {"text":"Done. Your app is building and Postgres is coming up. Want me to set up a custom domain too?","color":"#34d399"}
                 ]'>
              <div id="terminal-body-launch" class="bg-gray-950 p-6 font-mono text-sm leading-relaxed h-72 overflow-y-auto" data-terminal-animate-target="body">
                <p class="text-indigo-400 font-semibold">&gt; <span class="text-white font-normal">Deploy my api-service repo, set NODE_ENV to production, and add a Postgres database</span></p>
                <div data-terminal-animate-target="steps" class="mt-2"></div>
              </div>
            </div>
          </div>

          <!-- Debug -->
          <div id="terminal-panel-debug" class="hidden rounded-xl overflow-hidden ring-1 ring-white/10 shadow-2xl">
            <div class="flex items-center gap-2 px-4 py-3 bg-gray-900 border-b border-white/10">
              <span class="w-3 h-3 rounded-full bg-red-500"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
              <span class="w-3 h-3 rounded-full bg-green-500"></span>
              <span class="ml-4 text-xs text-gray-500 font-mono">claude — claude-code</span>
              <span class="ml-auto text-xs text-emerald-500 font-mono flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
                canine MCP connected
              </span>
            </div>
            <div data-controller="terminal-animate"
                 data-terminal-animate-loop-value="true"
                 data-terminal-animate-lines-value='[
                   {"text":"Let me pull the logs.","color":"#34d399"},
                   {"text":"→ get_project_logs(project: \"checkout-service\", lines: 50)","color":"#6b7280"},
                   {"text":"[ERROR] Redis::CannotConnectError: connection refused","color":"#f87171"},
                   {"text":"[ERROR] Redis::CannotConnectError: connection refused (31 more)","color":"#f87171"},
                   {"text":"Your checkout service can\u0027t reach Redis. Let me check the add-on.","color":"#34d399"},
                   {"text":"→ get_add_on_logs(add_on: \"checkout-redis\")","color":"#6b7280"},
                   {"text":"[ERROR] OOM: container exceeded 128Mi memory limit, killed","color":"#f87171"},
                   {"text":"Redis is crashing — its memory limit is too low. Want me to bump it to 256Mi and restart it?","color":"#34d399"}
                 ]'>
              <div id="terminal-body-debug" class="bg-gray-950 p-6 font-mono text-sm leading-relaxed h-72 overflow-y-auto" data-terminal-animate-target="body">
                <p class="text-indigo-400 font-semibold">&gt; <span class="text-white font-normal">Users are getting 500s on checkout. What's going on?</span></p>
                <div data-terminal-animate-target="steps" class="mt-2"></div>
              </div>
            </div>
          </div>

          <!-- Ship -->
          <div id="terminal-panel-ship" class="hidden rounded-xl overflow-hidden ring-1 ring-white/10 shadow-2xl">
            <div class="flex items-center gap-2 px-4 py-3 bg-gray-900 border-b border-white/10">
              <span class="w-3 h-3 rounded-full bg-red-500"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
              <span class="w-3 h-3 rounded-full bg-green-500"></span>
              <span class="ml-4 text-xs text-gray-500 font-mono">claude — claude-code</span>
              <span class="ml-auto text-xs text-emerald-500 font-mono flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
                canine MCP connected
              </span>
            </div>
            <div data-controller="terminal-animate"
                 data-terminal-animate-loop-value="true"
                 data-terminal-animate-lines-value='[
                   {"text":"Deploying main and spinning up the payments preview.","color":"#34d399"},
                   {"text":"→ deploy_project(project: \"api-service\", branch: \"main\")","color":"#6b7280"},
                   {"text":"✓ Deployment started — commit a3f9c12","color":"#34d399"},
                   {"text":"→ create_preview_deployment(project: \"api-service\", branch: \"feature/payments\")","color":"#6b7280"},
                   {"text":"✓ Preview live at payments-preview.canine.sh","color":"#34d399"},
                   {"text":"Production is deploying and your payments preview is up. Share that URL with your reviewer whenever you\u0027re ready.","color":"#34d399"}
                 ]'>
              <div id="terminal-body-ship" class="bg-gray-950 p-6 font-mono text-sm leading-relaxed h-72 overflow-y-auto" data-terminal-animate-target="body">
                <p class="text-indigo-400 font-semibold">&gt; <span class="text-white font-normal">Deploy main to production and spin up a preview for the feature/payments branch</span></p>
                <div data-terminal-animate-target="steps" class="mt-2"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      var terminalInitialized = false;
      function switchTerminal(name) {
        ['launch', 'debug', 'ship'].forEach(function(s) {
          document.getElementById('terminal-panel-' + s).classList.add('hidden');
          var tab = document.getElementById('terminal-tab-' + s);
          tab.classList.remove('bg-gray-800', 'ring-emerald-500/50', 'text-white');
          tab.classList.add('bg-gray-800/50', 'ring-white/10', 'text-gray-400');
        });
        var panel = document.getElementById('terminal-panel-' + name);
        panel.classList.remove('hidden');
        var active = document.getElementById('terminal-tab-' + name);
        active.classList.remove('bg-gray-800/50', 'ring-white/10', 'text-gray-400');
        active.classList.add('bg-gray-800', 'ring-emerald-500/50', 'text-white');

        var terminalEl = panel.querySelector('[data-controller="terminal-animate"]');
        if (terminalEl && window.Stimulus) {
          var ctrl = window.Stimulus.getControllerForElementAndIdentifier(terminalEl, 'terminal-animate');
          if (ctrl) ctrl.play();
        }

        if (terminalInitialized && window.innerWidth < 1024) {
          panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        terminalInitialized = true;
      }

      if (document.readyState !== 'loading') switchTerminal('launch');
      else document.addEventListener('DOMContentLoaded', function() { switchTerminal('launch'); });
    </script>

    <!-- Real Example -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/asciinema-player@3.10.0/dist/bundle/asciinema-player.css" />
    <script src="https://cdn.jsdelivr.net/npm/asciinema-player@3.10.0/dist/bundle/asciinema-player.min.js"></script>
    <div id="see-it-in-action" class="mx-auto max-w-7xl px-6 pb-24 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16" data-aos="fade-up">
        <h2 class="text-base font-semibold leading-7 text-emerald-400"><a href="#see-it-in-action" class="hover:underline underline-offset-4">See it in action</a></h2>
        <p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">A real example</p>
        <p class="mt-4 text-gray-400">Watch Claude Code deploy a project to Canine using the MCP server — from a real terminal session.</p>
      </div>
      <div class="relative overflow-hidden rounded-xl shadow-2xl ring-1 ring-white/10" data-aos="fade-up" data-aos-delay="150">
        <div id="mcp-cast-player" class="w-full"></div>
      </div>
      <script>
        document.addEventListener("DOMContentLoaded", function() {
          var container = document.getElementById("mcp-cast-player");
          var castFile = window.innerWidth < 768 ? "/mcp-mobile.cast" : "/mcp.cast";
          var player = AsciinemaPlayer.create(castFile, container, {
            autoPlay: false,
            loop: true,
            speed: 1.5,
            theme: "dracula",
            fit: "width",
            rows: 28
          });

          var started = false;
          var observer = new IntersectionObserver(function(entries) {
            if (entries[0].isIntersecting && !started) {
              started = true;
              player.play();
              observer.disconnect();
            }
          }, { threshold: 0.3 });
          observer.observe(container);
        });
      </script>
    </div>

    <!-- CTA -->
    <div class="mx-auto max-w-7xl px-6 pb-24 lg:px-8">
      <div class="relative rounded-2xl bg-gray-800/50 ring-1 ring-white/10 px-8 py-16 sm:px-16 text-center" data-aos="fade-up">
        <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">Automate your infrastructure workflow</h2>
        <p class="mt-4 text-gray-400 max-w-xl mx-auto">Sign up for Canine Cloud and connect your MCP client in under 5 minutes. No credit card required.</p>
        <div class="mt-8 flex items-center justify-center gap-x-6">
          <a href="<%= new_user_registration_path %>" class="rounded-md bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-emerald-400 transition">
            Get Started Free
          </a>
        </div>
      </div>
    </div>
  </main>

  <%= render "static/landing_page/footer" %>
</div>
