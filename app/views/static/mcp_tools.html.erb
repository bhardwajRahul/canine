<% content_for :meta_description, "Canine MCP Server — Control your infrastructure with AI. Deploy, debug, and manage Kubernetes apps through any MCP-compatible client." %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" />
<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
<script>
  ["DOMContentLoaded", "turbo:load"].forEach(function(e) {
    document.addEventListener(e, function() { AOS.init({ once: true, duration: 300, offset: 80, easing: "ease-out-cubic" }); });
  });
</script>

<div class="bg-gray-900 min-h-screen">
  <%= render "static/landing_page/navbar" %>

  <main>
    <!-- Hero -->
    <div class="relative isolate overflow-hidden">
      <div class="absolute inset-x-0 top-10 -z-10 flex transform-gpu justify-center overflow-hidden blur-3xl" aria-hidden="true">
        <div class="aspect-[1108/632] w-[69.25rem] flex-none bg-gradient-to-r from-[#10b981] to-[#6366f1] opacity-20" style="clip-path: polygon(73.6% 51.7%, 91.7% 11.8%, 100% 46.4%, 97.4% 82.2%, 92.5% 84.9%, 75.7% 64%, 55.3% 47.5%, 46.5% 49.4%, 45% 62.9%, 50.3% 87.2%, 21.3% 64.1%, 0.1% 100%, 5.4% 51.1%, 21.4% 63.9%, 58.9% 0.2%, 73.6% 51.7%)"></div>
      </div>

      <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-3xl text-center" data-aos="fade-up">
          <div class="inline-flex items-center gap-2 rounded-full bg-emerald-500/10 px-4 py-1.5 text-sm font-medium text-emerald-400 ring-1 ring-emerald-500/20 mb-8">
            <iconify-icon icon="lucide:cpu" class="text-base"></iconify-icon>
            Model Context Protocol
          </div>
          <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
            Your infrastructure,<br>controlled by AI
          </h1>
          <p class="mt-6 text-lg leading-8 text-gray-300 max-w-2xl mx-auto">
            Canine's MCP server lets you deploy, debug, and manage your Kubernetes applications through any MCP-compatible AI client. Ask your AI to check logs, roll back a deployment, or spin up a new service — it just works.
          </p>
          <div class="mt-10 flex items-center justify-center gap-x-6">
            <a href="<%= new_user_registration_path %>" class="rounded-md bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-emerald-400 transition">
              Get Started
            </a>
            <a href="https://docs.canine.sh" class="text-sm font-semibold text-white hover:text-emerald-400 transition">
              Read the docs <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- How it works -->
    <div class="mx-auto max-w-7xl px-6 lg:px-8 pb-24">
      <div class="mx-auto max-w-2xl text-center mb-16" data-aos="fade-up">
        <h2 class="text-base font-semibold leading-7 text-emerald-400">How it works</h2>
        <p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">Three steps to AI-powered ops</p>
      </div>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
        <div class="relative rounded-2xl bg-gray-800/50 ring-1 ring-white/10 p-8" data-aos="fade-up" data-aos-delay="0">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400 text-xl font-bold mb-6">1</div>
          <h3 class="text-lg font-semibold text-white mb-2">Connect your AI client</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Point Claude Code, Cursor, or any MCP-compatible client at your Canine instance. OAuth handles the rest.</p>
        </div>
        <div class="relative rounded-2xl bg-gray-800/50 ring-1 ring-white/10 p-8" data-aos="fade-up" data-aos-delay="100">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400 text-xl font-bold mb-6">2</div>
          <h3 class="text-lg font-semibold text-white mb-2">Ask in natural language</h3>
          <p class="text-gray-400 text-sm leading-relaxed">"Show me the logs for my API service" or "Deploy the latest commit to staging." Your AI understands 21 infrastructure tools.</p>
        </div>
        <div class="relative rounded-2xl bg-gray-800/50 ring-1 ring-white/10 p-8" data-aos="fade-up" data-aos-delay="200">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400 text-xl font-bold mb-6">3</div>
          <h3 class="text-lg font-semibold text-white mb-2">Infrastructure responds</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Canine executes the action on your cluster and returns structured results. Full audit trail, same permissions as the UI.</p>
        </div>
      </div>
    </div>

    <!-- Terminal Demo -->
    <div class="bg-gray-800/30 py-24">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16" data-aos="fade-up">
          <h2 class="text-base font-semibold leading-7 text-emerald-400">See it in action</h2>
          <p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">Diagnosing a 500 error in 60 seconds</p>
          <p class="mt-4 text-gray-400 text-sm">From Claude Code, after connecting via MCP</p>
        </div>
        <div class="mx-auto max-w-3xl" data-aos="fade-up" data-aos-delay="100">
          <div class="rounded-xl overflow-hidden ring-1 ring-white/10 shadow-2xl">
            <div class="flex items-center gap-2 px-4 py-3 bg-gray-900 border-b border-white/10">
              <span class="w-3 h-3 rounded-full bg-red-500"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
              <span class="w-3 h-3 rounded-full bg-green-500"></span>
              <span class="ml-4 text-xs text-gray-500 font-mono">claude — claude-code</span>
              <span class="ml-auto text-xs text-emerald-500 font-mono flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
                canine MCP connected
              </span>
            </div>
            <div class="bg-gray-950 p-6 font-mono text-sm leading-relaxed space-y-4">
              <!-- User prompt -->
              <div>
                <span class="text-indigo-400 font-semibold">></span>
                <span class="text-white ml-2">My API is returning 500s. What's going on?</span>
              </div>

              <!-- Tool call 1 -->
              <div class="pl-4 border-l-2 border-gray-800">
                <p class="text-gray-400 text-xs mb-1">Let me pull the recent logs.</p>
                <div class="bg-gray-900 rounded-lg px-4 py-3 mt-2">
                  <p class="text-amber-400 text-xs font-semibold mb-2">⚙ canine:get_project_logs</p>
                  <p class="text-gray-500 text-xs">project: "api-prod" &nbsp;·&nbsp; lines: 100</p>
                  <div class="mt-2 pt-2 border-t border-white/5 text-xs text-gray-500 space-y-0.5">
                    <p><span class="text-red-400">[ERROR]</span> 14:32:11 PG::ConnectionBad: could not connect to server</p>
                    <p><span class="text-red-400">[ERROR]</span> 14:32:11 connection pool exhausted (pool_size: 5, checked_out: 5)</p>
                    <p class="text-gray-600">... 47 more similar errors</p>
                  </div>
                </div>
              </div>

              <!-- Claude response -->
              <div class="pl-4 border-l-2 border-gray-800">
                <p class="text-gray-300 text-xs leading-relaxed">Your database connection pool is exhausted — all 5 connections are checked out. Let me see how many replicas you're running.</p>
              </div>

              <!-- Tool call 2 -->
              <div class="pl-4 border-l-2 border-gray-800">
                <div class="bg-gray-900 rounded-lg px-4 py-3">
                  <p class="text-amber-400 text-xs font-semibold mb-2">⚙ canine:get_project_details</p>
                  <p class="text-gray-500 text-xs">project: "api-prod"</p>
                  <div class="mt-2 pt-2 border-t border-white/5 text-xs text-gray-500 space-y-0.5">
                    <p>web: <span class="text-white">2 replicas</span> &nbsp;·&nbsp; 0.5 CPU / 512MB</p>
                    <p>db pool_size: <span class="text-white">5</span> &nbsp;·&nbsp; DB max_connections: <span class="text-white">5</span></p>
                  </div>
                </div>
              </div>

              <!-- Claude analysis -->
              <div class="pl-4 border-l-2 border-gray-800">
                <p class="text-gray-300 text-xs leading-relaxed">Found it. You have 2 replicas each opening up to 5 connections, but your database only allows 5 total. Scale down to 1 replica and the errors will stop. Want me to do that?</p>
              </div>

              <!-- User reply -->
              <div>
                <span class="text-indigo-400 font-semibold">></span>
                <span class="text-white ml-2">Yes</span>
              </div>

              <!-- Tool call 3 -->
              <div class="pl-4 border-l-2 border-gray-800">
                <div class="bg-gray-900 rounded-lg px-4 py-3">
                  <p class="text-amber-400 text-xs font-semibold mb-2">⚙ canine:scale_service</p>
                  <p class="text-gray-500 text-xs">project: "api-prod" &nbsp;·&nbsp; service: "web" &nbsp;·&nbsp; replicas: 1</p>
                  <div class="mt-2 pt-2 border-t border-white/5 text-xs text-gray-500">
                    <p><span class="text-emerald-400">✓</span> Rolling update started. Old pod draining...</p>
                  </div>
                </div>
                <p class="text-gray-300 text-xs mt-2">Done. 500s should clear within 30 seconds as traffic shifts to the remaining pod.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- All Tools -->
    <div class="mx-auto max-w-7xl px-6 py-24 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16" data-aos="fade-up">
        <h2 class="text-base font-semibold leading-7 text-emerald-400">What you can do</h2>
        <p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">Everything you need to operate</p>
      </div>

      <!-- Launching a new project -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-8" data-aos="fade-up">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/10">
            <iconify-icon icon="lucide:rocket" class="text-emerald-400"></iconify-icon>
          </div>
          <h3 class="text-xl font-semibold text-white">Launching a new project</h3>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up">
            <p class="text-sm font-semibold text-white mb-1">Connect your cluster</p>
            <p class="text-xs text-gray-400">Point to any Kubernetes cluster and start deploying in minutes — no kubectl required</p>
          </div>
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up" data-aos-delay="50">
            <p class="text-sm font-semibold text-white mb-1">Deploy from Git</p>
            <p class="text-xs text-gray-400">Tell Claude to create a project from your repo and push the first build</p>
          </div>
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up" data-aos-delay="100">
            <p class="text-sm font-semibold text-white mb-1">Set secrets and config</p>
            <p class="text-xs text-gray-400">Add environment variables and secrets without copy-pasting into a dashboard</p>
          </div>
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up" data-aos-delay="150">
            <p class="text-sm font-semibold text-white mb-1">Add a database in one step</p>
            <p class="text-xs text-gray-400">Search for a Postgres or Redis Helm chart and install it as a managed add-on</p>
          </div>
        </div>
      </div>

      <!-- Debugging production -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-8" data-aos="fade-up">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10">
            <iconify-icon icon="lucide:bug" class="text-amber-400"></iconify-icon>
          </div>
          <h3 class="text-xl font-semibold text-white">Debugging a production issue</h3>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up">
            <p class="text-sm font-semibold text-white mb-1">See what's failing right now</p>
            <p class="text-xs text-gray-400">Pull live logs from any service and let Claude identify the error pattern</p>
          </div>
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up" data-aos-delay="50">
            <p class="text-sm font-semibold text-white mb-1">Find out if the build broke</p>
            <p class="text-xs text-gray-400">Check whether the latest build succeeded or where it failed before it ever reached your cluster</p>
          </div>
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up" data-aos-delay="100">
            <p class="text-sm font-semibold text-white mb-1">Check your database too</p>
            <p class="text-xs text-gray-400">Pull logs from Postgres, Redis, or any add-on when your app can't connect</p>
          </div>
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up" data-aos-delay="150">
            <p class="text-sm font-semibold text-white mb-1">Understand the full picture</p>
            <p class="text-xs text-gray-400">Inspect replica count, resource limits, domains, and config all in one question</p>
          </div>
        </div>
      </div>

      <!-- Shipping and managing -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-8" data-aos="fade-up">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-violet-500/10">
            <iconify-icon icon="lucide:layers" class="text-violet-400"></iconify-icon>
          </div>
          <h3 class="text-xl font-semibold text-white">Shipping and managing</h3>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up">
            <p class="text-sm font-semibold text-white mb-1">Deploy without leaving your editor</p>
            <p class="text-xs text-gray-400">Trigger a deploy of the latest commit from any branch straight from Claude Code</p>
          </div>
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up" data-aos-delay="50">
            <p class="text-sm font-semibold text-white mb-1">Roll back in seconds</p>
            <p class="text-xs text-gray-400">Ask Claude to revert to any previous deployment the moment something goes wrong</p>
          </div>
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up" data-aos-delay="100">
            <p class="text-sm font-semibold text-white mb-1">Scale to handle the load</p>
            <p class="text-xs text-gray-400">Go from 1 to 20 replicas with zero downtime — or scale back down when traffic drops</p>
          </div>
          <div class="rounded-xl bg-gray-800/50 ring-1 ring-white/10 p-6" data-aos="fade-up" data-aos-delay="150">
            <p class="text-sm font-semibold text-white mb-1">Preview any branch</p>
            <p class="text-xs text-gray-400">Spin up an isolated environment for a feature branch and share the URL for review</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mx-auto max-w-7xl px-6 pb-24 lg:px-8">
      <div class="relative rounded-2xl bg-gray-800/50 ring-1 ring-white/10 px-8 py-16 sm:px-16 text-center" data-aos="fade-up">
        <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">Ready to let AI manage your infrastructure?</h2>
        <p class="mt-4 text-gray-400 max-w-xl mx-auto">Sign up for Canine Cloud and connect your MCP client in under 5 minutes. No credit card required.</p>
        <div class="mt-8 flex items-center justify-center gap-x-6">
          <a href="<%= new_user_registration_path %>" class="rounded-md bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-emerald-400 transition">
            Get Started Free
          </a>
        </div>
      </div>
    </div>
  </main>

  <%= render "static/landing_page/footer" %>
</div>
