<%= form_with(model: project) do |form| %>
  <%= render "shared/error_messages", resource: form.object %>
  <div class="space-y-4">
    <div class="text-base-content/50">
      Pull Request Apps are a way to deploy preview apps from pull requests.
    </div>
    <%= render(FormFieldComponent.new(label: "Pull Request Apps")) do %>
      <%= form.collection_select(
        :project_fork_status,
        Project.project_fork_statuses.keys,
        :to_s,
        :titleize,
        { include_blank: "Select a status" },
        { class: "select select-bordered w-full" },
      ) %>
    <% end %>

    <%= render(FormFieldComponent.new(
      label: "Cluster",
      description: "The cluster to deploy the preview apps to."
    )) do %>
      <%= render(RichSelectComponent.new(
        name: "project[project_fork_cluster_id]",
        id: "project_fork_cluster_id",
        collection: current_account.clusters,
        selected: form.object.project_fork_cluster_id,
        partial: "clusters/selector_item",
        placeholder: "Select a cluster"
      )) %>
    <% end %>
  </div>
  <div class="form-footer">
    <%= form.submit "Save", class: "btn btn-primary", data: { turbo_submits_with: "Saving..." } %>
  </div>
<% end %>