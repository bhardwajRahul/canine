<div class="tabs tabs-bordered mb-3" role="tablist">
  <% if project.development_environment? %>
    <%= link_to project_workbench_path(project), class: "tab hover:bg-base-content/15 #{'tab-active' if current_page?(project_workbench_path(project))}" do %>
      <div class="flex items-center gap-2">
        Workbench
        <iconify-icon icon="lucide:terminal"></iconify-icon>
      </div>
    <% end %>
  <% end %>
  <%= link_to project_deployments_path(project), class: "tab hover:bg-base-content/15 #{'tab-active' if current_page?(project_deployments_path(project))}" do %>
    <div class="flex items-center gap-2">
      Deployments
      <iconify-icon icon="lucide:rocket"></iconify-icon>
    </div>
  <% end %>
  <%= link_to project_services_path(project), class: "tab hover:bg-base-content/15 #{'tab-active' if current_page?(project_services_path(project))}" do %>
    <div class="flex items-center gap-2">
      Services
      <iconify-icon icon="lucide:server"></iconify-icon>
    </div>
  <% end %>
  <%= link_to project_environment_variables_path(project), class: "tab hover:bg-base-content/15 #{'tab-active' if current_page?(project_environment_variables_path(project))}" do %>
    <div class="flex items-center gap-2">
      Environment
      <iconify-icon icon="lucide:lock"></iconify-icon>
    </div>
  <% end %>
  <%= link_to project_processes_path(project), class: "tab hover:bg-base-content/15 #{'tab-active' if current_page?(project_processes_path(project))}" do %>
    <div class="flex items-center gap-2">
      Processes
      <iconify-icon icon="lucide:cpu"></iconify-icon>
    </div>
  <% end %>
  <%= link_to project_metrics_url(project), class: "tab hover:bg-base-content/15 #{'tab-active' if current_page?(project_metrics_url(project))}" do %>
    <div class="flex items-center gap-2">
      Metrics
      <iconify-icon icon="lucide:chart-line"></iconify-icon>
    </div>
  <% end %>
  <% unless project.development_environment? %>
    <% if @project.can_fork? %>
      <%= link_to project_project_forks_path(project), class: "tab hover:bg-base-content/15 #{'tab-active' if current_page?(project_project_forks_path(project))}" do %>
        <div class="flex items-center gap-2">
          Preview Apps
          <iconify-icon icon="lucide:eye"></iconify-icon>
        </div>
      <% end %>
    <% end %>
    <% if project.development_environment_enabled? && Flipper.enabled?(:development_environments, current_account) %>
      <%= link_to project_development_environments_path(project), class: "tab hover:bg-base-content/15 #{'tab-active' if current_page?(project_development_environments_path(project))}" do %>
        <div class="flex items-center gap-2">
          Development Environments
          <iconify-icon icon="lucide:laptop-minimal-check"></iconify-icon>
        </div>
      <% end %>
    <% end %>
  <% end %>
  <%= link_to edit_project_path(project), class: "tab hover:bg-base-content/15 #{'tab-active' if current_page?(edit_project_path(project))}" do %>
    <div class="flex items-center gap-2">
      Settings
      <iconify-icon icon="lucide:settings"></iconify-icon>
    </div>
  <% end %>
</div>
